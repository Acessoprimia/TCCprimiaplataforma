<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perfil - Primia</title>

    <link href="../css/entradaprofessor.css" rel="stylesheet">
    <%- include('../partials/headerprofessor.ejs') %>
</head>

<body>
    <!-- CONTEÚDO PRINCIPAL -->
    <main class="perfil-container">
        <!-- CARD DE PERFIL -->
        <article class="perfil-card">
            <!-- INFORMAÇÕES DO USUÁRIO -->
            <section class="usuario-info">
                <figure class="avatar-container">
                    <img src="../image/usuario.png" alt="Avatar do usuário" class="avatar">
                </figure>
                <article class="info-texto">
                    <h1 class="nome-usuario"><%= typeof usuario !== 'undefined' ? usuario.nome : 'Usuario do Professor' %></h1>
                    <p class="email-usuario"><%= typeof usuario !== 'undefined' ? usuario.email : 'usuarioprofessor@gmail.com' %></p>
                    <span class="matricula-usuario"><%= typeof usuario !== 'undefined' && usuario.materia ? usuario.materia : 'Materia: Exemplo' %></span>
                </article>
                <a href="/editarprofessor" class="btn-editar">Editar perfil</a>
            </section>

            <!-- MENU DE NAVEGAÇÃO -->
            <nav class="menu-navegacao">
                <a href="/forumprofessor" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/interrogacaou.png" alt="Fórum" class="icone">
                    </figure>
                    <span class="texto-menu">Fórum de Dúvidas</span>
                    <span class="seta-menu"></span>
                </a>

                <a href="/planoestudoprofessor" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/aulau.png" alt="Planos" class="icone">
                    </figure>
                    <span class="texto-menu">Planos de Aula</span>
                    <span class="seta-menu"></span>
                </a>

                <a href="/bibliotecaprofessor" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/bibliotecau.png" alt="Biblioteca" class="icone">
                    </figure>
                    <span class="texto-menu">Biblioteca</span>
                    <span class="seta-menu"></span>
                </a>

                <a href="/areapremiumprofessor" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/premiumu.png" alt="Premium" class="icone">
                    </figure>
                    <span class="texto-menu">Área Premium</span>
                    <span class="seta-menu"></span>
                </a>

                <a href="/contatoprofessor" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/contatou.png" alt="Contato" class="icone">
                    </figure>
                    <span class="texto-menu">Contato</span>
                    <span class="seta-menu"></span>
                </a>
            </nav>
        </article>
    </main>

</body>
<%- include('../partials/footer.ejs') %>

</html>
