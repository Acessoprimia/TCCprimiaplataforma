                        <p>Materia: Portugues | Status: agendado | Periodo: 13/11 a 17/11</p>
                        <nav>
                            <button data-admin-action="editar-conteudo">Editar</button>
                            <button data-admin-action="destacar-conteudo">Destacar</button>
                            <button data-admin-action="premium-conteudo">Marcar premium</button>
                            <button class="danger" data-admin-action="excluir-conteudo">Excluir</button>
                        </nav>
                    </article>
                    <article class="content-admin-card">
                        <span>Plano de estudo</span>
                        <h3>Cronograma ENEM</h3>
                        <p>Materia: Geral | Status: publicado | Acesso: gratuito</p>
                        <nav>
                            <button data-admin-action="editar-conteudo">Editar</button>
                            <button data-admin-action="destacar-conteudo">Destacar</button>
                            <button data-admin-action="premium-conteudo">Marcar premium</button>
                            <button class="danger" data-admin-action="excluir-conteudo">Excluir</button>
                        </nav>
                    </article>
                </section>
            </section>

            <section class="admin-panel" id="forum">
                <header class="panel-header">
                    <article>
                        <h2>Moderacao de denuncias</h2>
                        <p>Analise denuncias do forum sem responder ou participar diretamente das duvidas.</p>
                    </article>
                </header>

                <% // Futuramente listar denuncias do forum com motivo, autor da denuncia, conteudo denunciado e status. %>
                <% // O admin nao responde duvidas; apenas analisa, remove, ignora ou resolve denuncias. %>
                <section class="table-scroll">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Denuncia</th>
                                <th>Materia</th>
                                <th>Conteudo denunciado</th>
                                <th>Motivo</th>
                                <th>Status</th>
                                <th>Data</th>
                                <th>Acoes</th>
                            </tr>
                        </thead>
                        <tbody id="forumTabela">
                            <tr>
                                <td data-label="Denuncia">DEN-001</td>
                                <td data-label="Materia">Matematica</td>
                                <td data-label="Conteudo denunciado">Resposta com explicacao incorreta em fatoracao.</td>
                                <td data-label="Motivo">Conteudo incorreto</td>
