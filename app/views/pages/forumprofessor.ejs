<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fórum de Dúvidas</title>
    <%- include("../partials/headerprofessor.ejs") %>
        <link href="../css/forumprofessor.css" rel="stylesheet">
</head>

<body>
    <main>
        <h1 class="titulo-principal">Fórum de Dúvidas</h1>

        <% if (typeof msgErro !== 'undefined' && msgErro && msgErro.geral) { %>
            <p class="erro-msg"><%= msgErro.geral %></p>
        <% } %>

        <section class="filtro-section">
            <label for="materia-filtro" class="filtro-label">Filtro</label>
            <select id="materia-filtro" class="filtro-select">
                <option value="">Minha matéria</option>
                <% (materias || []).forEach((materia) => { %>
                    <option value="<%= materia.nome.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') %>">
                        <%= materia.nome %>
                    </option>
                <% }) %>
            </select>
        </section>

        <section class="duvidas-container">
            <% if (!duvidas || duvidas.length === 0) { %>
                <article class="card-duvida">
                    <p class="pergunta-texto">Ainda não há dúvidas para a sua matéria.</p>
                </article>
            <% } %>

            <% (duvidas || []).forEach((duvida) => { %>
                <article class="card-duvida" id="duvida-<%= duvida.id_duvida %>" data-materia="<%= duvida.materia_slug %>" data-duvida-id="<%= duvida.id_duvida %>">
                    <header class="card-header">
                        <figure class="avatar"></figure>
                        <section class="user-info">
                            <h3 class="user-name"><%= duvida.aluno_nome %></h3>
                            <p class="user-serie"><%= duvida.serie_formatada %> - <span class="tempo-relativo" data-segundos="<%= Number(duvida.segundos_desde_envio || 0) %>"><%= duvida.tempo %></span></p>
                        </section>
                        <span class="materia-tag">Matéria: <%= duvida.materia %></span>
                    </header>
                    <p class="pergunta-texto"><%= duvida.duvida %></p>

                    <% if (duvida.respostas && duvida.respostas.length) { %>
                        <section class="resposta-container" style="display: block;">
                            <% duvida.respostas.forEach((resposta) => { %>
                                <p class="resposta-texto"><strong>Resposta:</strong> <%= resposta.resposta %> <small>(<span class="tempo-relativo" data-segundos="<%= Number(resposta.segundos_desde_resposta || 0) %>"><%= resposta.tempo %></span>)</small></p>
                                <% if (professor && resposta.id_professor === professor.id_usuario) { %>
                                    <form action="/forumprofessor/respostas/<%= resposta.id_resposta %>/excluir" method="POST" class="form-excluir-forum" onsubmit="return confirm('Deseja excluir esta resposta?');">
                                        <input type="hidden" name="id_duvida" value="<%= duvida.id_duvida %>">
                                        <button class="btn-excluir-forum" type="submit">Excluir resposta</button>
                                    </form>
                                <% } %>
                            <% }) %>
                        </section>
                    <% } %>

                    <button class="btn-responder" data-duvida-id="<%= duvida.id_duvida %>">Responder</button>
                </article>
            <% }) %>
        </section>
    </main>

    <aside id="modal-resposta" class="modal">
        <section class="modal-content">
            <form action="/forumprofessor/responder" method="POST" id="form-resposta">
                <h2 class="modal-titulo">Responda a dúvida selecionada</h2>
                <input type="hidden" name="id_duvida" id="id-duvida-resposta">
                <textarea class="modal-textarea" name="resposta" placeholder="Responda a pergunta aqui" required></textarea>

                <section class="modal-opcoes">
                    <button class="btn-opcao materia-btn" type="button">
                        <%= professor && professor.materia ? professor.materia : 'Matéria vinculada' %>
                    </button>
                </section>

                <button class="btn-enviar" type="submit">Enviar</button>
                <button class="btn-fechar" id="btn-fechar-modal" type="button">×</button>
            </form>
        </section>
    </aside>

    <script src="../js/forumprofessor.js"></script>
</body>

</html>
