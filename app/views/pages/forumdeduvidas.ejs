<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fórum de Dúvidas</title>
    <link href="../css/forumdeduvidas.css" rel="stylesheet">
    <%- include('../partials/header.ejs') %>
</head>

<body>
    <main>
        <h1 class="titulo-principal">Fórum de Dúvidas</h1>

        <% if (typeof msgErro !== 'undefined' && msgErro && msgErro.geral) { %>
            <p class="erro-msg"><%= msgErro.geral %></p>
        <% } %>

        <section class="filtro-section">
            <label for="materia-filtro" class="filtro-label">Filtro</label>
            <select id="materia-filtro" class="filtro-select">
                <option value="">Todas as matérias</option>
                <% (materias || []).forEach((materia) => { %>
                    <option value="<%= materia.nome.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') %>">
                        <%= materia.nome %>
                    </option>
                <% }) %>
            </select>
        </section>

        <button class="btn-fazer-pergunta" id="btn-abrir-modal">Faça sua pergunta</button>

        <section class="duvidas-container">
            <% if (!duvidas || duvidas.length === 0) { %>
                <article class="card-duvida">
                    <p class="pergunta-texto">Ainda não há dúvidas cadastradas. Seja o primeiro a perguntar.</p>
                </article>
            <% } %>

            <% (duvidas || []).forEach((duvida) => { %>
                <article class="card-duvida" id="duvida-<%= duvida.id_duvida %>" data-materia="<%= duvida.materia_slug %>">
                    <header class="card-header">
                        <figure class="avatar"></figure>
                        <section class="user-info">
                            <h3 class="user-name"><%= duvida.aluno_nome %></h3>
                            <p class="user-serie"><%= duvida.serie_formatada %> - <span class="tempo-relativo" data-segundos="<%= Number(duvida.segundos_desde_envio || 0) %>"><%= duvida.tempo %></span></p>
                        </section>
                        <span class="materia-tag">Matéria: <%= duvida.materia %></span>
                    </header>
                    <p class="pergunta-texto"><%= duvida.duvida %></p>
                    <form action="/forumdeduvidas/<%= duvida.id_duvida %>/excluir" method="POST" class="form-excluir-forum" onsubmit="return confirm('Deseja excluir esta pergunta? As respostas dela também serão removidas.');">
                        <button class="btn-excluir-forum" type="submit">Excluir pergunta</button>
                    </form>
                    <button class="btn-ver-resposta">
                        <%= duvida.respostas && duvida.respostas.length ? 'Ver resposta' : 'Aguardando resposta' %>
                    </button>
                    <section class="resposta-container" style="display: none;">
                        <% if (duvida.respostas && duvida.respostas.length) { %>
                            <% duvida.respostas.forEach((resposta) => { %>
                                <h4 class="resposta-titulo">Resposta</h4>
                                <header class="resposta-header">
                                    <figure class="avatar-professor"></figure>
                                    <section class="professor-info">
                                        <h5 class="professor-name"><%= resposta.professor_nome %></h5>
                                        <p class="professor-materia">Professor(a) de <%= resposta.materia || duvida.materia %> - <span class="tempo-relativo" data-segundos="<%= Number(resposta.segundos_desde_resposta || 0) %>"><%= resposta.tempo %></span></p>
                                    </section>
                                </header>
                                <p class="resposta-texto"><strong>Resposta:</strong> <%= resposta.resposta %></p>
                            <% }) %>
                        <% } else { %>
                            <p class="resposta-texto">Essa dúvida ainda não recebeu resposta.</p>
                        <% } %>
                    </section>
                </article>
            <% }) %>
        </section>

        <button class="btn-add-fixo" id="btn-add-fixo" aria-label="Adicionar pergunta">+</button>
    </main>

    <aside id="modal-pergunta" class="modal">
        <section class="modal-content">
            <form action="/forumdeduvidas" method="POST">
                <h2 class="modal-titulo">Tire Sua Dúvida:</h2>
                <textarea class="modal-textarea" name="duvida" placeholder="Escreva sua pergunta aqui" required></textarea>
                <select class="modal-select" name="id_materia" required>
                    <option value="">Matéria</option>
                    <% (materias || []).forEach((materia) => { %>
                        <option value="<%= materia.id_materia %>"><%= materia.nome %></option>
                    <% }) %>
                </select>
                <button class="btn-enviar" type="submit">Enviar</button>
                <button class="btn-fechar" id="btn-fechar-modal" type="button">×</button>
            </form>
        </section>
    </aside>
    <%- include('../partials/footer.ejs') %>
        <script src="../js/forumdeduvidas.js"></script>
</body>

</html>
