<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perfil - Plataforma Primia</title>

    <link href="../css/entrada.css" rel="stylesheet">
    <%- include('../partials/header.ejs') %>
</head>

<body>
    <!-- CONTEÚDO PRINCIPAL -->
    <main class="perfil-container">
        <!-- CARD DE PERFIL -->
        <article class="perfil-card">
            <!-- INFORMAÇÕES DO USUÁRIO -->
            <section class="usuario-info">
                <figure class="avatar-container">
                    <img src="../image/usuario.webp" alt="Avatar do usuário" class="avatar">
                </figure>
                <article class="info-texto">
                    <h1 class="nome-usuario"><%= typeof usuario !== 'undefined' ? usuario.nome : 'Usuario do Aluno' %></h1>
                    <p class="email-usuario"><%= typeof usuario !== 'undefined' ? usuario.email : 'usuarioaluno@gmail.com' %></p>
                    <span class="matricula-usuario">RA: <%= typeof usuario !== 'undefined' && usuario.ra ? usuario.ra : '0000' %></span> <br>
                    <span class="matricula-usuario">Série: <%= typeof usuario !== 'undefined' && usuario.serie ? usuario.serie : 'Não informada' %></span>
                </article>
                <a href="/editarperfil" class="btn-editar">Editar perfil</a>
            </section>

            <!-- MENU DE NAVEGAÇÃO -->
            <nav class="menu-navegacao">
                <a href="/forumdeduvidas" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/interrogacaou.webp" alt="Fórum" class="icone">
                    </figure>
                    <span class="texto-menu">Fórum de Dúvidas</span>
                    <span class="seta-menu">›</span>
                </a>

                <a href="/planoestudo" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/aulau.webp" alt="Planos" class="icone">
                    </figure>
                    <span class="texto-menu">Planos de Estudo</span>
                    <span class="seta-menu">›</span>
                </a>

                <a href="/biblioteca" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/bibliotecau.webp" alt="Biblioteca" class="icone">
                    </figure>
                    <span class="texto-menu">Biblioteca</span>
                    <span class="seta-menu">›</span>
                </a>

                <a href="/areapremium" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/premiumu.webp" alt="Premium" class="icone">
                    </figure>
                    <span class="texto-menu">Área Premium</span>
                    <span class="seta-menu">›</span>
                </a>

                <a href="/contato" class="menu-item">
                    <figure class="icone-menu">
                        <img src="../image/contatou.webp" alt="Contato" class="icone">
                    </figure>
                    <span class="texto-menu">Contato</span>
                    <span class="seta-menu">›</span>
                </a>
            </nav>
        </article>
    </main>

</body>
<%- include('../partials/footer.ejs') %>

</html>
