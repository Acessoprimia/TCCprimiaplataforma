            <section class="admin-panel" id="relatorios">
                <header class="panel-header">
                    <article>
                        <h2>Relatorios administrativos</h2>
                        <p>Indicadores simulados para acompanhar crescimento e engajamento.</p>
                    </article>
                </header>

                <% // Futuramente gerar relatorios com queries agregadas e filtros por periodo, materia e tipo de usuario. %>
                <section class="report-grid">
                    <article><strong>+18%</strong><span>Crescimento de cadastros</span></article>
                    <article><strong>84</strong><span>Duvidas respondidas no mes</span></article>
                    <article><strong>Biologia</strong><span>Conteudo mais acessado</span></article>
