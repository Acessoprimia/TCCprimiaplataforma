<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conteudos - Painel Administrativo Primia</title>
    <link href="/css/admin.css" rel="stylesheet">
    <%- include('../../partials/headeradmin.ejs') %>
</head>

<body>
    <main class="admin-page">
        <section class="admin-mobile-intro">
            <p class="admin-kicker">Painel Administrativo</p>
            <h1>Conteudos</h1>
            <p>Materias, livros, videoaulas, simulados, cronogramas e planos de estudo.</p>
        </section>

        <%- include('../../partials/adminSidebar.ejs', { activeAdminPage: 'conteudos' }) %>

        <section class="admin-content">
            <section class="admin-panel" id="materias">
                <header class="panel-header panel-header-actions">
                    <article>
                        <h2>Materias da plataforma</h2>
                        <p>Controle as materias usadas em biblioteca, simulados, forum e planos.</p>
                    </article>
                    <button class="admin-button primary" type="button" data-admin-action="adicionar-materia">Adicionar materia</button>
                </header>

                <% // A lista abaixo e populada por conteudos.js a partir de MATERIAS_MOCK, com a %>
                <% // contagem de conteudos vinculados calculada a partir de CONTEUDOS_MOCK. %>
                <% // Futuramente buscar materias da tabela Materia e impedir exclusao se houver conteudos vinculados. %>
                <p class="materias-resumo" id="materiasContagem"></p>
                <section class="materias-lista" id="materiasLista"></section>
            </section>

            <section class="admin-panel" id="conteudos">
                <header class="panel-header panel-header-actions">
                    <article>
                        <h2>Gerenciamento de conteudos</h2>
                        <p>Biblioteca, livros, videoaulas, simulados, cronogramas e planos de estudo.</p>
                    </article>
                    <button class="admin-button primary" type="button" data-admin-action="adicionar-conteudo">Adicionar conteudo</button>
                </header>

                <% // Os cards abaixo sao calculados a partir de CONTEUDOS_MOCK em tempo de execucao, %>
                <% // para refletir edicoes, exclusoes e mudancas de acesso feitas na tabela. %>
                <div class="resumo-cards" id="conteudosResumo"></div>

                <div class="admin-search-bar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    <input type="search" id="conteudosBusca" placeholder="Buscar por titulo ou autor..." aria-label="Buscar conteudos">
                </div>

                <nav class="admin-filtros" aria-label="Filtrar por tipo de conteudo">
                    <button type="button" class="filtro-btn ativo" data-filtro-conteudos="todos">Todos</button>
                    <button type="button" class="filtro-btn" data-filtro-conteudos="livro">Livros</button>
                    <button type="button" class="filtro-btn" data-filtro-conteudos="videoaula">Videoaulas</button>
                    <button type="button" class="filtro-btn" data-filtro-conteudos="simulado">Simulados</button>
                    <button type="button" class="filtro-btn" data-filtro-conteudos="cronograma">Cronogramas</button>
                    <button type="button" class="filtro-btn" data-filtro-conteudos="plano-de-estudo">Planos de estudo</button>
                </nav>

                <div class="admin-filtros-painel">
                    <div class="admin-filtro-bloco">
                        <span class="admin-filtros-label">Materia</span>
                        <select class="filtro-select" id="conteudosFiltroMateria" aria-label="Filtrar por materia">
                            <option value="todas">Todas as materias</option>
                        </select>
                    </div>

                    <div class="admin-filtro-bloco">
                        <span class="admin-filtros-label">Status</span>
                        <nav class="admin-filtros" aria-label="Filtrar por status">
                            <button type="button" class="filtro-btn ativo" data-filtro-status-conteudo="todos">Todos</button>
                            <button type="button" class="filtro-btn" data-filtro-status-conteudo="publicado">Publicado</button>
                            <button type="button" class="filtro-btn" data-filtro-status-conteudo="rascunho">Rascunho</button>
                            <button type="button" class="filtro-btn" data-filtro-status-conteudo="agendado">Agendado</button>
                            <button type="button" class="filtro-btn" data-filtro-status-conteudo="arquivado">Arquivado</button>
                        </nav>
                    </div>

                    <div class="admin-filtro-bloco">
                        <span class="admin-filtros-label">Acesso</span>
                        <nav class="admin-filtros" aria-label="Filtrar por acesso">
                            <button type="button" class="filtro-btn ativo" data-filtro-acesso-conteudo="todos">Todos</button>
                            <button type="button" class="filtro-btn" data-filtro-acesso-conteudo="gratuito">Gratuito</button>
                            <button type="button" class="filtro-btn" data-filtro-acesso-conteudo="premium">Premium</button>
                        </nav>
                    </div>
                </div>

                <% // A tabela abaixo e populada em tempo de execucao por conteudos.js a partir de %>
                <% // CONTEUDOS_MOCK (app/public/js/admin/conteudosMock.js). Busca, filtros e paginacao %>
                <% // operam sobre esse array. Futuramente CONTEUDOS_MOCK sera substituido pela resposta %>
                <% // de uma API (ex.: GET /api/admin/conteudos) sem precisar alterar este template. %>
                <section class="table-scroll">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Titulo</th>
                                <th>Tipo</th>
                                <th>Materia</th>
                                <th>Status</th>
                                <th>Acesso</th>
                                <th>Autor</th>
                                <th>Data</th>
                                <th>Acoes</th>
                            </tr>
                        </thead>
                        <tbody id="conteudosTabela"></tbody>
                    </table>
                </section>

                <footer class="admin-pagination">
                    <p class="admin-pagination-info" id="conteudosPaginacaoInfo">Carregando conteudos...</p>
                    <div class="admin-pagination-controles" id="conteudosPaginacaoControles"></div>
                </footer>
            </section>
        </section>
    </main>

    <%- include('../../partials/adminModals.ejs') %>

    <script src="/js/admin/common.js"></script>
    <script src="/js/admin/conteudosMock.js"></script>
    <script src="/js/admin/conteudos.js"></script>
    <%- include('../../partials/footer.ejs') %>
</body>

</html>
