<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <meta property="og:title" content="Primia — Plataforma de estudos para o futuro" />
    <meta property="og:description" content="Estude de forma inteligente com a Primia: conteúdos atualizados, reforço personalizado e foco no seu futuro." />
    <meta property="og:image" content="https://plataforma-primia.onrender.com/image/logo_para_open_graph_1x.webp" />
    <meta property="og:url" content="https://plataforma-primia.onrender.com" />
    <meta property="og:type" content="website" />

    <title>PrimiaHome</title>

    <link href="../css/telainicial.css" rel="stylesheet">
    <link href="../css/media.css" rel="stylesheet">
    <%- include('../partials/header.ejs') %>

</head>

<body>
    <section class="page-content-wrapper">
        <!-- MAIN: INSCRIÇÃO + IMAGEM -->
        <main>
            <aside>
                <h2><span>Inscreva-se agora</span></h2>
                <h2 class="primia">na Primia</h2>
                <p>
                    A Primia é um espaço colaborativo feito para alunos e professores que querem aprender, ensinar e
                    crescer juntos.
                    Aqui, você pode tirar dúvidas, compartilhar conhecimento e acompanhar o desempenho de forma simples
                    e prática.
                    Junte-se à nossa comunidade e transforme a forma de aprender!
                </p>
                <nav>
                    <a class="inscreva" href="/logincadastro">Inscreva-se</a>
                </nav>
            </aside>

            <article>
                <img src="../image/roxoestudo.webp" alt="homem em dúvida">
            </article>
        </main>

        <!-- JORNADA COLABORATIVA -->
        <section id="jornada">
            <article class="jornada-card">
                <h2 class="jornada-title">Uma jornada de aprendizagem colaborativa...</h2>
                <p class="jornada-text">
                    Valorizar cada estudante como único(a) foi o que nos permitiu desenvolver uma
                    solução completa e que promove a personalização do processo de aprendizado
                    em cada segmento de ensino.
                </p>
                <nav class="jornada-buttons">
                    <button class="jornada-btn">Dúvidas</button>
                    <button class="jornada-btn">Interação</button>
                    <button class="jornada-btn">Perfis</button>
                </nav>
            </article>

           
            
        </section>

        <!-- RECURSOS PARA ESCOLA -->
        <section id="recursos">
            <figure class="recursos-image">
                <img src="../image/escolab.webp" alt="Estudantes em sala de aula">
            </figure>
            <article class="recursos-content">
                <h2 class="recursos-title">E ainda os melhores <span class="destaque">recursos para sua escola
                        brilhar!</span></h2>
                <p class="recursos-text">
                    O Brilhando Junto é um programa de ações e conteúdos que tem como
                    finalidade apoiar, de forma estratégica, pedagógica e afetiva, todas as
                    escolas parceiras em suas jornadas de excelência. Trabalhamos a formação,
                    a retenção e captação de novos alunos de forma muito mais!
                </p>
            </article>
        </section>

        <!-- MATERIAS - CARROSSEL -->
        <section id="materias">
            <h2 class="material">Explore as matérias:</h2>
            <nav class="carrossel">
                <button class="pass" id="prev">&lt;&lt;</button>
                <section class="conteudo" id="carrossel">
                    <ul class="lista" id="lista">
                        <li class="slide" data-materia="Matemática">
                            <a href="#" aria-label="Matemática" title="Matemática">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="5" r="1.4" />
                                    <path d="M12 6.4 L6 20" />
                                    <path d="M12 6.4 L18 20" />
                                    <path d="M8.5 14 L15.5 14" />
                                </svg>
                            </a>
                        </li>
                        <li class="slide" data-materia="História">
                            <a href="#" aria-label="História" title="História">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 4 H21" />
                                    <path d="M4 6 H20" />
                                    <path d="M4 20 H20" />
                                    <path d="M6 6 V20" />
                                    <path d="M9 6 V20" />
                                    <path d="M12 6 V20" />
                                    <path d="M15 6 V20" />
                                    <path d="M18 6 V20" />
                                </svg>
                            </a>
                        </li>
                        <li class="slide" data-materia="Sociologia">
                            <a href="#" aria-label="Sociologia" title="Sociologia">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="9" cy="8" r="2.6" />
                                    <path d="M4 19 c0-3.3 2.2-5.2 5-5.2 s5 1.9 5 5.2" />
                                    <circle cx="17" cy="9" r="2.1" />
                                    <path d="M14.6 13.4 c1-0.6 2.1-0.8 3-0.5 c1.8 0.6 3 2.3 3 4.6" />
                                </svg>
                            </a>
                        </li>
                        <li class="slide" data-materia="Inglês">
                            <a href="#" aria-label="Inglês" title="Inglês">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 5 H20 V15 H10 L6 19 V15 H4 Z" />
                                    <path d="M8 9 H16" />
                                    <path d="M8 12 H13" />
                                </svg>
                            </a>
                        </li>
                        <li class="slide" data-materia="Biologia">
                            <a href="#" aria-label="Biologia" title="Biologia">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M6 19 C4 12 8 5 19 4 C18 15 12 19 6 19 Z" />
                                    <path d="M6 19 C10 14 13 10 18 6" />
                                </svg>
                            </a>
                        </li>
                        <li class="slide" data-materia="Física">
                            <a href="#" aria-label="Física" title="Física">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none" />
                                    <ellipse cx="12" cy="12" rx="9" ry="3.6" />
                                    <ellipse cx="12" cy="12" rx="9" ry="3.6" transform="rotate(60 12 12)" />
                                    <ellipse cx="12" cy="12" rx="9" ry="3.6" transform="rotate(120 12 12)" />
                                </svg>
                            </a>
                        </li>
                        <li class="slide" data-materia="Geografia">
                            <a href="#" aria-label="Geografia" title="Geografia">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="9" />
                                    <path d="M3 12 H21" />
                                    <path d="M12 3 C15.5 6.5 15.5 17.5 12 21 C8.5 17.5 8.5 6.5 12 3 Z" />
                                </svg>
                            </a>
                        </li>
                        <li class="slide" data-materia="Química">
                            <a href="#" aria-label="Química" title="Química">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M10 3 H14" />
                                    <path d="M11 3 V9 L5.5 19 C5 20 5.6 21 6.7 21 H17.3 C18.4 21 19 20 18.5 19 L13 9 V3" />
                                    <path d="M8 15 H16" />
                                </svg>
                            </a>
                        </li>
                        <li class="slide" data-materia="Português">
                            <a href="#" aria-label="Português" title="Português">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 6 C10 4.5 7 4 4 4.5 V17.5 C7 17 10 17.5 12 19" />
                                    <path d="M12 6 C14 4.5 17 4 20 4.5 V17.5 C17 17 14 17.5 12 19" />
                                    <path d="M12 6 V19" />
                                </svg>
                            </a>
                        </li>
                    </ul>
                </section>
                <button class="pass" id="next">&gt;&gt;</button>
            </nav>
            <div class="materias-dots" id="materias-dots"></div>
        </section>

        <!-- ACESSO -->
        <section id="acesso">
            <h2 class="areas">Áreas de Acesso</h2>
            <section class="acesso-container">
                <article class="acesso-card1">
                    <h3>Alunos</h3>
                    <p>Esclareça suas dúvidas e participe das discussões.</p>
                    <a href="/cadastro">
                        <p>Cadastre-se >></p>
                    </a>
                </article>

                <article class="acesso-card3">
                    <h3>Professor</h3>
                    <p>Tire dúvidas, dê suporte aos alunos e acompanhe atividades.</p>
                    <a href="/cadastroprofessor">
                        <p>Cadastre-se >></p>
                    </a>
                </article>
            </section>
        </section>
    </section>

    <script src="../js/carrossel.js"></script>

    <%- include('../partials/footer.ejs') %>
</body>

</html>
