<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suporte - Painel Administrativo Primia</title>
    <link href="/css/admin.css" rel="stylesheet">
    <%- include('../../partials/headeradmin.ejs') %>
</head>

<body>
    <main class="admin-page">
        <section class="admin-mobile-intro">
            <p class="admin-kicker">Painel Administrativo</p>
            <h1>Suporte</h1>
            <p>Gerenciamento de tickets: denuncias do forum e mensagens enviadas pela pagina de contato.</p>
        </section>

        <%- include('../../partials/adminSidebar.ejs', { activeAdminPage: 'suporte' }) %>

        <section class="admin-content">
            <section class="admin-panel" id="suporte">
                <header class="panel-header">
                    <article>
                        <h2>Central de suporte</h2>
                        <p>Acompanhe denuncias do forum e mensagens de contato em um unico lugar.</p>
                    </article>
                </header>

                <% // Os cards abaixo sao calculados a partir de DENUNCIAS_MOCK e CONTATOS_MOCK em %>
                <% // tempo de execucao, para refletir mudancas de status feitas nas tabelas abaixo. %>
                <div class="resumo-cards" id="suporteResumo"></div>

                <nav class="admin-abas" aria-label="Tipo de ticket" role="tablist">
                    <button type="button" class="aba-botao aba-ativa" id="abaDenunciasBotao" role="tab" aria-selected="true" aria-controls="painelDenuncias" data-aba-alvo="denuncias">
                        Denuncias
                    </button>
                    <button type="button" class="aba-botao" id="abaContatoBotao" role="tab" aria-selected="false" aria-controls="painelContato" data-aba-alvo="contato">
                        Contato
                    </button>
                </nav>

                <% // As tabelas abaixo sao populadas em tempo de execucao por suporte.js a partir de %>
                <% // DENUNCIAS_MOCK e CONTATOS_MOCK (app/public/js/admin/suporteMock.js). Busca, %>
                <% // filtros, paginacao e o menu de acoes operam sobre esses arrays. Futuramente eles %>
                <% // serao substituidos pela resposta de uma API (ex.: GET /api/admin/denuncias e %>
                <% // GET /api/admin/contatos) sem precisar alterar este template. %>

                <section class="aba-conteudo" id="painelDenuncias" role="tabpanel" aria-labelledby="abaDenunciasBotao" data-aba-painel="denuncias">
                    <div class="admin-search-bar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="search" id="denunciasBusca" placeholder="Buscar por codigo, usuario ou motivo..." aria-label="Buscar denuncias">
                    </div>

                    <div class="admin-filtros-painel">
                        <div class="admin-filtro-bloco">
                            <span class="admin-filtros-label">Status</span>
                            <nav class="admin-filtros" aria-label="Filtrar denuncias por status">
                                <button type="button" class="filtro-btn ativo" data-filtro-status-denuncia="todos">Todos</button>
                                <button type="button" class="filtro-btn" data-filtro-status-denuncia="aberto">Aberto</button>
                                <button type="button" class="filtro-btn" data-filtro-status-denuncia="em_analise">Em analise</button>
                                <button type="button" class="filtro-btn" data-filtro-status-denuncia="resolvido">Resolvido</button>
                            </nav>
                        </div>

                        <div class="admin-filtro-bloco">
                            <span class="admin-filtros-label">Prioridade</span>
                            <nav class="admin-filtros" aria-label="Filtrar denuncias por prioridade">
                                <button type="button" class="filtro-btn ativo" data-filtro-prioridade-denuncia="todos">Todas</button>
                                <button type="button" class="filtro-btn" data-filtro-prioridade-denuncia="alta">Alta</button>
                                <button type="button" class="filtro-btn" data-filtro-prioridade-denuncia="media">Media</button>
                                <button type="button" class="filtro-btn" data-filtro-prioridade-denuncia="baixa">Baixa</button>
                            </nav>
                        </div>

                        <div class="admin-filtro-bloco">
                            <span class="admin-filtros-label">Tipo</span>
                            <nav class="admin-filtros" aria-label="Filtrar denuncias por tipo de conteudo">
                                <button type="button" class="filtro-btn ativo" data-filtro-tipo-denuncia="todos">Todos</button>
                                <button type="button" class="filtro-btn" data-filtro-tipo-denuncia="forum">Forum</button>
                                <button type="button" class="filtro-btn" data-filtro-tipo-denuncia="videoaula">Videoaula</button>
                                <button type="button" class="filtro-btn" data-filtro-tipo-denuncia="livro">Livro</button>
                                <button type="button" class="filtro-btn" data-filtro-tipo-denuncia="simulado">Simulado</button>
                                <button type="button" class="filtro-btn" data-filtro-tipo-denuncia="outros">Outros</button>
                            </nav>
                        </div>
                    </div>

                    <section class="table-scroll">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Usuario</th>
                                    <th>Tipo</th>
                                    <th>Motivo</th>
                                    <th>Prioridade</th>
                                    <th>Status</th>
                                    <th>Data</th>
                                    <th>Acoes</th>
                                </tr>
                            </thead>
                            <tbody id="denunciasTabela"></tbody>
                        </table>
                    </section>

                    <footer class="admin-pagination">
                        <p class="admin-pagination-info" id="denunciasPaginacaoInfo">Carregando denuncias...</p>
                        <div class="admin-pagination-controles" id="denunciasPaginacaoControles"></div>
                    </footer>
                </section>

                <section class="aba-conteudo oculto" id="painelContato" role="tabpanel" aria-labelledby="abaContatoBotao" data-aba-painel="contato">
                    <div class="admin-search-bar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="search" id="contatoBusca" placeholder="Buscar por nome, email ou assunto..." aria-label="Buscar mensagens de contato">
                    </div>

                    <section class="table-scroll">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Nome</th>
                                    <th>Email</th>
                                    <th>Assunto</th>
                                    <th>Status</th>
                                    <th>Data</th>
                                    <th>Acoes</th>
                                </tr>
                            </thead>
                            <tbody id="contatoTabela"></tbody>
                        </table>
                    </section>

                    <footer class="admin-pagination">
                        <p class="admin-pagination-info" id="contatoPaginacaoInfo">Carregando mensagens...</p>
                        <div class="admin-pagination-controles" id="contatoPaginacaoControles"></div>
                    </footer>
                </section>
            </section>
        </section>
    </main>

    <%- include('../../partials/adminModals.ejs') %>

    <script src="/js/admin/common.js"></script>
    <script src="/js/admin/suporteMock.js"></script>
    <script src="/js/admin/suporte.js"></script>
    <%- include('../../partials/footer.ejs') %>
</body>

</html>
