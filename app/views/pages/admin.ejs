                                <td data-label="Data">12/04/2026</td>
                                <td data-label="Acoes" class="table-actions">
                                    <button data-admin-action="visualizar-denuncia">Visualizar</button>
                                    <button data-admin-action="analisar-denuncia">Analisar</button>
                                    <button data-admin-action="ignorar-denuncia">Ignorar</button>
                                    <button data-admin-action="resolver-denuncia">Resolver</button>
                                    <button class="danger" data-admin-action="remover-conteudo-denunciado">Remover conteudo</button>
                                </td>
                            </tr>
                            <tr>
                                <td data-label="Denuncia">DEN-002</td>
                                <td data-label="Materia">Filosofia</td>
                                <td data-label="Conteudo denunciado">Pergunta com linguagem inadequada.</td>
                                <td data-label="Motivo">Linguagem inadequada</td>
                                <td data-label="Status"><span class="status ativo">Em analise</span></td>
                                <td data-label="Data">10/04/2026</td>
                                <td data-label="Acoes" class="table-actions">
                                    <button data-admin-action="visualizar-denuncia">Visualizar</button>
                                    <button data-admin-action="analisar-denuncia">Analisar</button>
                                    <button data-admin-action="ignorar-denuncia">Ignorar</button>
                                    <button data-admin-action="resolver-denuncia">Resolver</button>
                                    <button class="danger" data-admin-action="remover-conteudo-denunciado">Remover conteudo</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </section>
            </section>

            <section class="admin-panel" id="premium">
                <header class="panel-header panel-header-actions">
                    <article>
                        <h2>Controle da area premium</h2>
                        <p>Gerencie acessos, periodos e beneficios premium.</p>
                    </article>
                    <button class="admin-button primary" type="button" data-admin-action="editar-beneficios">Editar beneficios</button>
                </header>

                <% // Futuramente ligar premium ao banco e ao gateway de pagamento, salvando periodo_inicio, periodo_fim e status_pagamento. %>
                <section class="premium-grid" id="premiumLista">
                    <article class="premium-card">
                        <h3>Julia Fernandes</h3>
                        <p>Premium ativo ate 30/05/2026</p>
                        <nav>
                            <button data-admin-action="controlar-periodo-premium">Controlar periodo</button>
                            <button class="danger" data-admin-action="remover-premium">Remover premium</button>
                        </nav>
                    </article>
                    <article class="premium-card">
                        <h3>Pedro Martins</h3>
                        <p>Conta gratuita</p>
                        <nav>
                            <button data-admin-action="liberar-premium">Liberar premium</button>
                            <button data-admin-action="controlar-periodo-premium">Controlar periodo</button>
                        </nav>
                    </article>
                </section>
            </section>

            <section class="admin-panel" id="suporte">
                <header class="panel-header">
