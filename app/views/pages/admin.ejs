                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Professor</th>
                                <th>Email</th>
                                <th>Tipo</th>
                                <th>Status</th>
                                <th>Materia</th>
                                <th>ID acesso</th>
                                <th>Acoes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td data-label="Professor">Ana Lima</td>
                                <td data-label="Email">ana.prof@primia.com</td>
                                <td data-label="Tipo"><span class="badge professor">Professor</span></td>
                                <td data-label="Status"><span class="status ativo">Ativo</span></td>
                                <td data-label="Materia">Biologia</td>
                                <td data-label="ID acesso">PROF-0012</td>
                                <td data-label="Acoes" class="table-actions">
                                    <button data-admin-action="ver-login-professor">Ver login</button>
                                    <button data-admin-action="alterar-tipo-conta">Alterar tipo</button>
                                    <button data-admin-action="bloquear-conta">Bloquear</button>
                                    <button class="danger" data-admin-action="excluir-conta">Excluir</button>
                                </td>
                            </tr>
                            <tr>
                                <td data-label="Professor">Rafael Costa</td>
                                <td data-label="Email">rafael.prof@primia.com</td>
                                <td data-label="Tipo"><span class="badge professor">Professor</span></td>
                                <td data-label="Status"><span class="status ativo">Ativo</span></td>
                                <td data-label="Materia">Matematica</td>
                                <td data-label="ID acesso">PROF-0015</td>
                                <td data-label="Acoes" class="table-actions">
                                    <button data-admin-action="ver-login-professor">Ver login</button>
                                    <button data-admin-action="alterar-tipo-conta">Alterar tipo</button>
                                    <button data-admin-action="bloquear-conta">Bloquear</button>
                                    <button class="danger" data-admin-action="excluir-conta">Excluir</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </section>
            </section>

            <section class="admin-panel" id="conteudos">
                <header class="panel-header panel-header-actions">
                    <article>
                        <h2>Gerenciamento de conteudos</h2>
                        <p>Biblioteca, livros, videoaulas, cronogramas, planos e simulados.</p>
                    </article>
                    <button class="admin-button primary" type="button" data-admin-action="adicionar-conteudo">Adicionar conteudo</button>
                </header>

                <% // Futuramente salvar, editar, destacar e marcar conteudos como premium no banco de dados. %>
                <section class="content-grid" id="conteudosLista">
                    <article class="content-admin-card">
                        <span>Biblioteca</span>
                        <h3>Livro de Matematica Basica</h3>
                        <p>Materia: Matematica | Status: publicado | Acesso: gratuito</p>
                        <nav>
                            <button data-admin-action="editar-conteudo">Editar</button>
                            <button data-admin-action="destacar-conteudo">Destacar</button>
                            <button data-admin-action="premium-conteudo">Marcar premium</button>
                            <button class="danger" data-admin-action="excluir-conteudo">Excluir</button>
                        </nav>
                    </article>
                    <article class="content-admin-card">
                        <span>Videoaula</span>
