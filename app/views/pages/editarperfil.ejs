<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Perfil - Primia</title>
    <%- include('../partials/header.ejs') %>
    <link href="../css/editarperfil.css" rel="stylesheet">
</head>
<body>

<main>
    <div class="pagina-container">
        <h1 class="titulo-pagina">Editar Perfil</h1>

        <section class="form-container">
            <form class="editar-perfil" action="/editarperfil" method="POST">

                <!-- AVATAR -->
                <figure class="avatar-container">
                    <img src="../image/usuario.png" alt="Foto de perfil" id="preview-avatar" class="avatar">
                    <label for="avatar-upload" class="avatar-edit-btn">Alterar foto</label>
                    <input type="file" id="avatar-upload" name="avatar" accept="image/*" hidden>
                </figure>

                <!-- NOME -->
                <label class="campo-wrapper">
                    <figure class="icone-campo">
                        <img src="../image/usuario.png" alt="Usuário" class="icone">
                    </figure>
                    <input type="text" id="nome" name="nome" placeholder="Nome completo" class="input-campo" value="Usuário do Aluno">
                </label>
                <p id="erro-nome" class="erro-msg"></p>

                <!-- EMAIL -->
                <label class="campo-wrapper">
                    <figure class="icone-campo">
                        <img src="../image/usuario.png" alt="Email" class="icone">
                    </figure>
                    <input type="email" id="email" name="email" placeholder="Email" class="input-campo" value="usuarioaluno@gmail.com">
                </label>
                <p id="erro-email" class="erro-msg"></p>

                <!-- SÉRIE -->
                <label class="campo-wrapper">
                    <figure class="icone-campo">
                        <img src="../image/ra.png" alt="Série" class="icone">
                    </figure>
                    <select id="serie" name="serie" class="input-campo select-campo">
                        <option value="" disabled selected>Série escolar</option>
                        <option value="1ano">1º Ano</option>
                        <option value="2ano">2º Ano</option>
                        <option value="3ano">3º Ano</option>
                    </select>
                </label>
                <p id="erro-serie" class="erro-msg"></p>

                <!-- RA (readonly) -->
                <label class="campo-wrapper readonly-wrapper">
                    <figure class="icone-campo">
                        <img src="../image/ra.png" alt="RA" class="icone">
                    </figure>
                    <input type="number" id="matricula" name="matricula" placeholder="RA" class="input-campo" value="0000" readonly>
                </label>

                <!-- DATA DE NASCIMENTO (readonly) -->
                <label class="campo-wrapper readonly-wrapper">
                    <figure class="icone-campo">
                        <img src="../image/data.png" alt="Data de Nascimento" class="icone">
                    </figure>
                    <input type="date" id="data-nascimento" name="data-nascimento" class="input-campo" value="2000-01-01" readonly>
                </label>

                <!-- SENHA -->
                <label class="campo-wrapper">
                    <figure class="icone-campo">
                        <img src="../image/cadeado.png" alt="Senha" class="icone">
                    </figure>
                    <input type="password" id="senha" name="senha" placeholder="Nova senha (opcional)" class="input-campo">
                    <span class="mostrar-senha" onclick="toggleSenha('senha')">
                        <img src="../image/olho_fechado.png" alt="mostrar senha" class="icone-olho">
                    </span>
                </label>
                <ul id="regras-senha" class="regras-senha-modern">
                    <li id="tamanho">8 a 15 caracteres</li>
                    <li id="maiuscula">Uma letra maiúscula</li>
                    <li id="minuscula">Uma letra minúscula</li>
                    <li id="numero">Um número</li>
                    <li id="especial">Um caractere especial (@, !, #, $, %, &)</li>
                </ul>

                <!-- CONFIRMAR SENHA -->
                <label class="campo-wrapper">
                    <figure class="icone-campo">
                        <img src="../image/cadeado.png" alt="Repetir Senha" class="icone">
                    </figure>
                    <input type="password" id="confirmar-senha" name="confirmar-senha" placeholder="Confirmar nova senha" class="input-campo">
                    <span class="mostrar-senha" onclick="toggleSenha('confirmar-senha')">
                        <img src="../image/olho_fechado.png" alt="mostrar senha" class="icone-olho">
                    </span>
                </label>
                <p id="erro-confirmar" class="erro-msg"></p>

                <button type="submit" class="botao-submit">Salvar alterações</button>

            </form>
        </section>
    </div>
</main>

<%- include('../partials/footer.ejs') %>
<script src="../js/editarperfil.js"></script>
</body>
</html>