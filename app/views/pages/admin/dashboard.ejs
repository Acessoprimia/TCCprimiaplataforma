<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Painel Administrativo Primia</title>
    <link href="/css/admin.css" rel="stylesheet">
    <%- include('../../partials/headeradmin.ejs') %>
</head>

<body>
    <%
        // Metadados de apresentacao dos cards (rotulo, descricao e icone) ficam aqui,
        // separados dos valores em si. "metricas" chega pronto do backend (hoje mock em
        // app/mocks/adminDashboardMock.js, futuramente Models.admin.buscarMetricasDashboard).
        const cartoesMetricas = [
            { chave: "totalAlunos", rotulo: "Total de alunos", descricao: "Alunos ativos na plataforma", icone: "alunos" },
            { chave: "totalProfessores", rotulo: "Total de professores", descricao: "Professores cadastrados", icone: "professores" },
            { chave: "contasProfessor", rotulo: "Contas professor", descricao: "Logins docentes cadastrados", icone: "login" },
            { chave: "denunciasAbertas", rotulo: "Denuncias abertas", descricao: "Moderacao aguardando analise", icone: "alerta", alerta: true },
            { chave: "conteudosCadastrados", rotulo: "Conteudos cadastrados", descricao: "Biblioteca, videos e planos", icone: "conteudos" },
            { chave: "usuariosPremium", rotulo: "Usuarios premium", descricao: "Acessos premium ativos", icone: "premium" },
            { chave: "mensagensContato", rotulo: "Mensagens de contato", descricao: "Chamados abertos", icone: "mensagens" },
        ];

        const iconesMetricas = {
            alunos: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>',
            professores: '<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><polyline points="17 11 19 13 23 9"></polyline>',
            login: '<circle cx="7.5" cy="15.5" r="5.5"></circle><path d="M21 2l-9.6 9.6"></path><path d="M15.5 7.5l3 3L22 7l-3-3"></path>',
            alerta: '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line>',
            conteudos: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>',
            premium: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>',
            mensagens: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22 6 12 13 2 6"></polyline>',
        };

        const rotulosPrioridade = { alta: "Alta", media: "Media", baixa: "Baixa" };

        // Geometria do grafico de crescimento, calculada a partir de "grafico.series".
        // Trocar os valores mockados por agregacoes reais nao exige mudar nada abaixo.
        const chartWidth = 640;
        const chartHeight = 240;
        const chartPad = { top: 16, right: 16, bottom: 30, left: 34 };
        const plotWidth = chartWidth - chartPad.left - chartPad.right;
        const plotHeight = chartHeight - chartPad.top - chartPad.bottom;

        const todosValores = grafico.series.flatMap((serie) => serie.valores);
        const escalaMaxima = Math.max(10, Math.ceil((Math.max(...todosValores) * 1.15) / 10) * 10);
        const totalPontos = grafico.labels.length;
        const passoX = totalPontos > 1 ? plotWidth / (totalPontos - 1) : 0;

        const coordX = (indice) => chartPad.left + passoX * indice;
        const coordY = (valor) => chartPad.top + plotHeight - (valor / escalaMaxima) * plotHeight;
        const linhaBase = (chartPad.top + plotHeight).toFixed(1);

        const linhasGrade = [0, 0.25, 0.5, 0.75, 1].map((fracao) => ({
            y: (chartPad.top + plotHeight * (1 - fracao)).toFixed(1),
            valor: Math.round(escalaMaxima * fracao),
        }));

        const seriesGrafico = grafico.series.map((serie) => {
            const pontos = serie.valores.map((valor, indice) => ({
                x: coordX(indice).toFixed(1),
                y: coordY(valor).toFixed(1),
            }));
            const linha = pontos.map((p, i) => `${i === 0 ? "M" : "L"}${p.x},${p.y}`).join(" ");
            const area = `${linha} L${coordX(totalPontos - 1).toFixed(1)},${linhaBase} L${coordX(0).toFixed(1)},${linhaBase} Z`;
            return { ...serie, pontos, linha, area };
        });
    %>

    <main class="admin-page">
        <section class="admin-mobile-intro">
            <p class="admin-kicker">Painel Administrativo</p>
            <h1>Gestao Primia</h1>
            <p>Controle usuarios, conteudos, suporte, relatorios e configuracoes em um unico lugar.</p>
        </section>

        <%- include('../../partials/adminSidebar.ejs', { activeAdminPage: 'dashboard' }) %>

        <section class="admin-content">
            <section class="admin-hero" id="dashboard">
                <article>
                    <p class="admin-kicker">Painel Administrativo Primia</p>
                    <h1>Bem-vindo ao centro de gestao</h1>
                </article>
                <a href="/admin/usuarios" class="admin-primary-action">Gerenciar usuarios</a>
            </section>

            <section class="admin-metrics" aria-label="Metricas principais">
                <% cartoesMetricas.forEach((cartao) => { %>
                    <article class="metric-card <%= cartao.alerta ? 'alerta' : '' %>">
                        <header class="metric-card-head">
                            <i class="metric-card-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <%- iconesMetricas[cartao.icone] %>
                                </svg>
                            </i>
                            <span><%= cartao.rotulo %></span>
                        </header>
                        <strong><%= metricas[cartao.chave] %></strong>
                        <p><%= cartao.descricao %></p>
                    </article>
                <% }) %>
            </section>

            <section class="admin-row">
                <article class="admin-panel chart-panel">
                    <header class="panel-header">
                        <article>
                            <h2>Crescimento da plataforma</h2>
                            <p>Cadastros, duvidas respondidas e uso premium ao longo dos ultimos meses.</p>
                        </article>
                    </header>
                    <% // Futuramente montar grafico com agregacoes por data vindas do banco. %>
                    <section class="chart-frame">
                        <svg class="growth-chart" viewBox="0 0 <%= chartWidth %> <%= chartHeight %>" role="img" aria-label="Grafico de linhas mostrando crescimento de cadastros, duvidas respondidas e uso premium">
                            <defs>
                                <linearGradient id="growthChartArea" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="<%= seriesGrafico[0].cor %>" stop-opacity="0.32" />
                                    <stop offset="100%" stop-color="<%= seriesGrafico[0].cor %>" stop-opacity="0" />
                                </linearGradient>
                            </defs>

                            <% linhasGrade.forEach((linha) => { %>
                                <line class="chart-grid-line" x1="<%= chartPad.left %>" y1="<%= linha.y %>" x2="<%= chartWidth - chartPad.right %>" y2="<%= linha.y %>"></line>
                                <text class="chart-grid-label" x="<%= chartPad.left - 8 %>" y="<%= linha.y %>" text-anchor="end"><%= linha.valor %></text>
                            <% }) %>

                            <% grafico.labels.forEach((rotulo, indice) => { %>
                                <text class="chart-axis-label" x="<%= coordX(indice).toFixed(1) %>" y="<%= chartHeight - 10 %>" text-anchor="middle"><%= rotulo %></text>
                            <% }) %>

                            <path class="chart-area" d="<%= seriesGrafico[0].area %>" fill="url(#growthChartArea)"></path>

                            <% seriesGrafico.forEach((serie) => { %>
                                <path class="chart-line" d="<%= serie.linha %>" stroke="<%= serie.cor %>" fill="none"></path>
                                <% serie.pontos.forEach((ponto) => { %>
                                    <circle class="chart-point" cx="<%= ponto.x %>" cy="<%= ponto.y %>" r="3.5" fill="<%= serie.cor %>"></circle>
                                <% }) %>
                            <% }) %>
                        </svg>
                    </section>
                    <section class="chart-caption">
                        <% grafico.series.forEach((serie) => { %>
                            <span><i class="chart-caption-dot" style="background-color: <%= serie.cor %>"></i><%= serie.nome %></span>
                        <% }) %>
                    </section>
                </article>

                <article class="admin-panel">
                    <header class="panel-header">
                        <article>
                            <h2>Pendencias importantes</h2>
                            <p>Itens que precisam de revisao administrativa.</p>
                        </article>
                    </header>
                    <ul class="admin-list">
                        <% pendencias.forEach((item) => { %>
                            <li class="prioridade-<%= item.prioridade %>">
                                <span class="admin-list-item-head">
                                    <strong><%= item.titulo %></strong>
                                    <i class="priority-badge <%= item.prioridade %>"><%= rotulosPrioridade[item.prioridade] %></i>
                                </span>
                                <span><%= item.descricao %></span>
                            </li>
                        <% }) %>
                    </ul>
                </article>
            </section>
        </section>
    </main>

    <%- include('../../partials/footer.ejs') %>
</body>

</html>
