<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plano de Aulas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
    <link href="../css/planoestudo.css" rel="stylesheet">
    <%- include('../partials/header.ejs') %>
</head>

<body>
    <main>
        <section class="plano-estudos">
            <h1 class="titulo-principal">Planos de Estudos</h1>
            <figure class="tabela-container">
                <img src="../image/planoaulam.webp" alt="Tabela de Planos de Estudos" class="tabela-image">
            </figure>
        </section>

        <section class="prioridades">
            <h2 class="titulo-secao">Prioridades</h2>
            <ul class="lista-prioridades">
                <li class="item-lista">
                    <input type="checkbox" id="prioridade1" class="checkbox">
                    <label for="prioridade1" class="label-checkbox">1ª Prioridade</label>
                    <button class="btn-editar" onclick="editar(this)" aria-label="editar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9466" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
    </svg>
</button>
                </li>
                <li class="item-lista">
                    <input type="checkbox" id="prioridade2" class="checkbox">
                    <label for="prioridade2" class="label-checkbox">2ª Prioridade</label>
                    <button class="btn-editar" onclick="editar(this)" aria-label="editar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9466" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
    </svg>
</button>
                </li>
                <li class="item-lista">
                    <input type="checkbox" id="prioridade3" class="checkbox">
                    <label for="prioridade3" class="label-checkbox">3ª Prioridade</label>
                    <button class="btn-editar" onclick="editar(this)" aria-label="editar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9466" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
    </svg>
</button>
                </li>
                <li class="item-lista">
                    <input type="checkbox" id="prioridade4" class="checkbox">
                    <label for="prioridade4" class="label-checkbox">4ª Prioridade</label>
                    <button class="btn-editar" onclick="editar(this)" aria-label="editar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9466" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
    </svg>
</button>
                </li>
            </ul>
        </section>

        <section class="conteudos">
            <h2 class="titulo-secao">Conteúdos da Semana</h2>
            <ul class="lista-conteudos">
                <li class="item-lista">
                    <input type="checkbox" id="conteudo1" class="checkbox">
                    <label for="conteudo1" class="label-checkbox">1º Conteúdo</label>
                    <button class="btn-editar" onclick="editar(this)" aria-label="editar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9466" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
    </svg>
</button>
                </li>
                <li class="item-lista">
                    <input type="checkbox" id="conteudo2" class="checkbox">
                    <label for="conteudo2" class="label-checkbox">2º Conteúdo</label>
                    <button class="btn-editar" onclick="editar(this)" aria-label="editar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9466" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
    </svg>
</button>
                </li>
                <li class="item-lista">
                    <input type="checkbox" id="conteudo3" class="checkbox">
                    <label for="conteudo3" class="label-checkbox">3º Conteúdo</label>
                    <button class="btn-editar" onclick="editar(this)" aria-label="editar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9466" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
    </svg>
</button>
                </li>
                <li class="item-lista">
                    <input type="checkbox" id="conteudo4" class="checkbox">
                    <label for="conteudo4" class="label-checkbox">4º Conteúdo</label>
                    <button class="btn-editar" onclick="editar(this)" aria-label="editar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9466" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
    </svg>
</button>
                </li>
            </ul>
        </section>
    </main>

    <%- include('../partials/footer.ejs') %>
    <script src="../js/planoestudo.js"></script>
</body>

</html>