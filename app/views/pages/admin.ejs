<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Administrativo - Primia</title>
    <link href="/css/admin.css" rel="stylesheet">
    <%- include('../partials/headeradmin.ejs') %>
</head>

<body>
    <% // Futuramente estes dados devem vir do banco de dados por meio do controller da rota /admin. %>
    <% // Exemplo: const dashboard = await AdminDashboardService.montarResumo(); %>
    <main class="admin-page">
        <section class="admin-mobile-intro">
            <p class="admin-kicker">Painel Administrativo</p>
            <h1>Gestao Primia</h1>
            <p>Controle usuarios, conteudos, forum, premium e suporte em um unico lugar.</p>
        </section>

        <aside class="admin-sidebar" aria-label="Navegacao administrativa">
            <section class="admin-profile">
                <figure class="admin-avatar">
                    <img src="/image/usuario.webp" alt="Administrador Primia">
                </figure>
                <h2>Administrador</h2>
                <p>admin@primia.com</p>
                <span>Acesso administrativo</span>
            </section>

            <nav class="admin-side-menu">
                <a href="#dashboard" class="admin-side-link ativo">Dashboard</a>
                <a href="#usuarios" class="admin-side-link">Usuarios</a>
                <a href="#professores" class="admin-side-link">Professores</a>
                <a href="#conteudos" class="admin-side-link">Conteudos</a>
                <a href="#forum" class="admin-side-link">Forum</a>
                <a href="#premium" class="admin-side-link">Premium</a>
                <a href="#suporte" class="admin-side-link">Suporte</a>
                <a href="#relatorios" class="admin-side-link">Relatorios</a>
                <a href="#configuracoes" class="admin-side-link">Configuracoes</a>
            </nav>
        </aside>

        <section class="admin-content">
            <section class="admin-hero" id="dashboard">
                <article>
                    <p class="admin-kicker">Painel Administrativo Primia</p>
                    <h1>Bem-vindo ao centro de gestao</h1>
                    <p>Use estes dados simulados para validar o fluxo administrativo antes da integracao com banco, sessoes e permissoes reais.</p>
                </article>
                <a href="#usuarios" class="admin-primary-action">Gerenciar usuarios</a>
            </section>

            <section class="admin-metrics" aria-label="Metricas principais">
                <% // Futuramente buscar quantidade real de usuarios, professores, duvidas, conteudos e premium no banco. %>
                <article class="metric-card">
                    <span>Total de alunos</span>
                    <strong>245</strong>
                    <p>Alunos ativos na plataforma</p>
                </article>
                <article class="metric-card">
                    <span>Total de professores</span>
                    <strong>18</strong>
                    <p>Professores cadastrados</p>
                </article>
                <article class="metric-card">
                    <span>Contas professor</span>
                    <strong>18</strong>
                    <p>Logins docentes cadastrados</p>
                </article>
                <article class="metric-card alerta">
                    <span>Denuncias abertas</span>
                    <strong>5</strong>
                    <p>Moderacao aguardando analise</p>
                </article>
                <article class="metric-card">
                    <span>Conteudos cadastrados</span>
                    <strong>74</strong>
                    <p>Biblioteca, videos e planos</p>
                </article>
                <article class="metric-card">
                    <span>Usuarios premium</span>
                    <strong>39</strong>
                    <p>Acessos premium ativos</p>
                </article>
                <article class="metric-card">
                    <span>Mensagens de contato</span>
                    <strong>12</strong>
                    <p>Chamados abertos</p>
                </article>
            </section>

            <section class="admin-row">
                <article class="admin-panel">
                    <header class="panel-header">
                        <article>
                            <h2>Resumo de atividade</h2>
                            <p>Movimentacao simulada dos ultimos dias.</p>
                        </article>
                    </header>
                    <% // Futuramente montar grafico com agregacoes por data vindas do banco. %>
                    <section class="mini-chart" aria-label="Grafico de cadastros">
                        <span style="height: 42%"></span>
                        <span style="height: 68%"></span>
                        <span style="height: 56%"></span>
                        <span style="height: 82%"></span>
                        <span style="height: 63%"></span>
                        <span style="height: 92%"></span>
                        <span style="height: 74%"></span>
                    </section>
                    <section class="chart-caption">
                        <span>Cadastros</span>
                        <span>Duvidas respondidas</span>
                        <span>Uso premium</span>
                    </section>
                </article>

                <article class="admin-panel">
                    <header class="panel-header">
                        <article>
                            <h2>Pendencias importantes</h2>
                            <p>Itens que precisam de revisao administrativa.</p>
                        </article>
                    </header>
                    <ul class="admin-list">
                        <li><strong>18 professores</strong><span>Contas docentes cadastradas para consulta</span></li>
                        <li><strong>5 denuncias</strong><span>Moderacao do forum pendente</span></li>
                        <li><strong>4 conteudos</strong><span>Materiais esperando publicacao</span></li>
                        <li><strong>12 mensagens</strong><span>Contato aguardando resposta</span></li>
                    </ul>
                </article>
            </section>

            <section class="admin-panel" id="materias">
                <header class="panel-header panel-header-actions">
                    <article>
                        <h2>Materias da plataforma</h2>
                        <p>Controle as materias usadas em biblioteca, simulados, forum e planos.</p>
                    </article>
                    <button class="admin-button primary" type="button" data-admin-action="adicionar-materia">Adicionar materia</button>
                </header>

                <% // Futuramente buscar materias da tabela materias e impedir exclusao se houver conteudos vinculados. %>
