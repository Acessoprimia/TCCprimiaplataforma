                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>Tipo</th>
                                <th>Status</th>
                                <th>ID acesso</th>
                                <th>Acoes</th>
                            </tr>
                        </thead>
                        <tbody id="usuariosTabela">
                            <tr>
                                <td data-label="Nome">Maria Souza</td>
                                <td data-label="Email">maria.aluna@primia.com</td>
                                <td data-label="Tipo"><span class="badge aluno">Aluno</span></td>
                                <td data-label="Status"><span class="status ativo">Ativo</span></td>
                                <td data-label="ID acesso">ALU-0001</td>
                                <td data-label="Acoes" class="table-actions">
                                    <button data-admin-action="ver-login-usuario">Ver login</button>
                                    <button data-admin-action="alterar-tipo-conta">Alterar tipo</button>
                                    <button data-admin-action="bloquear-conta">Bloquear</button>
                                    <button class="danger" data-admin-action="excluir-conta">Excluir</button>
                                </td>
                            </tr>
                            <tr>
                                <td data-label="Nome">Prof. Carlos Lima</td>
                                <td data-label="Email">carlos.prof@primia.com</td>
                                <td data-label="Tipo"><span class="badge professor">Professor</span></td>
                                <td data-label="Status"><span class="status ativo">Ativo</span></td>
                                <td data-label="ID acesso">PROF-0018</td>
                                <td data-label="Acoes" class="table-actions">
                                    <button data-admin-action="ver-login-usuario">Ver login</button>
                                    <button data-admin-action="alterar-tipo-conta">Alterar tipo</button>
                                    <button data-admin-action="bloquear-conta">Bloquear</button>
                                    <button class="danger" data-admin-action="excluir-conta">Excluir</button>
                                </td>
                            </tr>
                            <tr>
                                <td data-label="Nome">Equipe Primia</td>
                                <td data-label="Email">admin@primia.com</td>
                                <td data-label="Tipo"><span class="badge admin">Admin</span></td>
                                <td data-label="Status"><span class="status ativo">Ativo</span></td>
                                <td data-label="ID acesso">ADM-0001</td>
                                <td data-label="Acoes" class="table-actions">
                                    <button data-admin-action="ver-login-usuario">Ver login</button>
                                    <button data-admin-action="alterar-tipo-conta">Alterar tipo</button>
                                    <button data-admin-action="bloquear-conta">Bloquear</button>
                                    <button class="danger" data-admin-action="excluir-conta">Excluir</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </section>
            </section>

            <section class="admin-panel" id="professores">
                <header class="panel-header panel-header-actions">
                    <article>
                        <h2>Consulta de professores</h2>
                        <p>Visualizacao de dados principais e login docente, sem fluxo de alteracao direta.</p>
                    </article>
                </header>

                <% // Futuramente buscar professores no banco com JOIN entre usuarios, professores e materias. %>
                <% // Esta secao deve ser somente leitura; alteracoes de login ou materia devem ocorrer em fluxo separado e auditado. %>
